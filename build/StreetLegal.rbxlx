local function addMiniDistrict(name, pos, size, color)
	local frame = Instance.new("Frame")
	frame.Name = name
	frame.Position = pos
	frame.Size = size
	frame.BackgroundColor3 = color
	frame.BackgroundTransparency = 0.18
	frame.BorderSizePixel = 0
	frame.Parent = mapCanvas
